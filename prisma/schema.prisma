generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  active
  inactive
  suspended
}

enum CompanyPlan {
  starter
  growth
  enterprise
}

enum MemberRole {
  owner
  admin
  finance
  operator
}

enum MemberStatus {
  invited
  active
  inactive
}

enum AuditAction {
  create
  update
  delete
  login
  logout
}

enum InfluencerStatus {
  active
  invited
  paused
  declined
}

enum CampaignStatus {
  draft
  active
  paused
  finished
}

enum WalletTransactionType {
  commission
  bonus
  adjustment
  payout
  refund
}

enum WalletTransactionDirection {
  credit
  debit
}

enum WalletTransactionStatus {
  pending
  available
  cancelled
  reversed
}

enum BalanceReleaseMode {
  immediate
  monthly
}

enum InfluencerCouponStatus {
  active
  inactive
}

enum CommissionEventStatus {
  pending
  approved
  blocked
  available
  cancelled
  reversed
}

enum CommissionSourceType {
  order
  spreadsheet
  manual
  challenge
}

enum ImportedOrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum OrderImportSource {
  spreadsheet
}

enum InfluencerPortalAccountStatus {
  active
  inactive
}

enum CampaignInfluencerStatus {
  invited
  active
  paused
  finished
}

enum InfluencerChallengeStatus {
  draft
  active
  finished
  cancelled
}

enum InfluencerChallengeSubmissionStatus {
  pending
  approved
  rejected
}

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  status    CompanyStatus @default(active)
  plan      CompanyPlan   @default(starter)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  members     CompanyMember[]
  auditLogs   AuditLog[]
  influencers Influencer[]
  campaigns   Campaign[]
  walletAccounts WalletAccount[]
  walletTransactions WalletTransaction[]
  financialSettings CompanyFinancialSettings?
  influencerCoupons InfluencerCoupon[]
  commissionEvents CommissionEvent[]
  importedOrders ImportedOrder[]
  influencerTimelineEvents InfluencerTimelineEvent[]
  influencerPortalAccounts InfluencerPortalAccount[]
  campaignInfluencers CampaignInfluencer[]
  influencerChallenges InfluencerChallenge[]
  influencerChallengeSubmissions InfluencerChallengeSubmission[]
  influencerChallengeScores InfluencerChallengeScore[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships CompanyMember[]
  auditLogs   AuditLog[]
  influencerTimelineEvents InfluencerTimelineEvent[]

  @@map("users")
}

model Influencer {
  id         String           @id @default(cuid())
  companyId  String           @map("company_id")
  name       String
  email      String
  phone      String?
  instagram  String?
  status     InfluencerStatus @default(invited)
  couponCode String?          @map("coupon_code")
  notes      String?
  archivedAt DateTime?        @map("archived_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  walletAccount WalletAccount?
  walletTransactions WalletTransaction[]
  coupons InfluencerCoupon[]
  commissionEvents CommissionEvent[]
  timelineEvents InfluencerTimelineEvent[]
  portalAccount InfluencerPortalAccount?
  campaignLinks CampaignInfluencer[]
  challengeSubmissions InfluencerChallengeSubmission[]
  challengeScores InfluencerChallengeScore[]

  @@unique([companyId, email])
  @@unique([companyId, instagram])
  @@unique([companyId, couponCode])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("influencers")
}

model InfluencerTimelineEvent {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  influencerId String   @map("influencer_id")
  userId       String?  @map("user_id")
  type         String
  title        String
  description  String?
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, influencerId, createdAt])
  @@index([companyId, type])
  @@map("influencer_timeline_events")
}

model Campaign {
  id            String         @id @default(cuid())
  companyId     String         @map("company_id")
  name          String
  description   String?
  objective     String?
  status        CampaignStatus @default(draft)
  startsAt      DateTime?      @map("starts_at")
  endsAt        DateTime?      @map("ends_at")
  plannedBudget Decimal?       @map("planned_budget") @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  influencerLinks CampaignInfluencer[]

  @@index([companyId, status])
  @@index([companyId, startsAt])
  @@index([companyId, createdAt])
  @@map("campaigns")
}

model InfluencerPortalAccount {
  id           String                        @id @default(cuid())
  companyId    String                        @map("company_id")
  influencerId String                        @unique @map("influencer_id")
  email        String
  passwordHash String                        @map("password_hash")
  status       InfluencerPortalAccountStatus @default(active)
  lastLoginAt  DateTime?                     @map("last_login_at")
  createdAt    DateTime                      @default(now()) @map("created_at")
  updatedAt    DateTime                      @updatedAt @map("updated_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
  @@unique([companyId, influencerId])
  @@index([companyId, status])
  @@map("influencer_portal_accounts")
}

model CampaignInfluencer {
  id           String                   @id @default(cuid())
  companyId    String                   @map("company_id")
  campaignId   String                   @map("campaign_id")
  influencerId String                   @map("influencer_id")
  status       CampaignInfluencerStatus @default(active)
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([companyId, campaignId, influencerId])
  @@index([companyId, campaignId])
  @@index([companyId, influencerId])
  @@index([companyId, status])
  @@map("campaign_influencers")
}

model InfluencerChallenge {
  id               String                    @id @default(cuid())
  companyId        String                    @map("company_id")
  title            String
  description      String
  prizeDescription String?                   @map("prize_description")
  status           InfluencerChallengeStatus @default(draft)
  startsAt         DateTime?                 @map("starts_at")
  endsAt           DateTime?                 @map("ends_at")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  company     Company                         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submissions InfluencerChallengeSubmission[]
  scores      InfluencerChallengeScore[]

  @@index([companyId, status])
  @@index([companyId, startsAt])
  @@index([companyId, createdAt])
  @@map("influencer_challenges")
}

model InfluencerChallengeSubmission {
  id           String                              @id @default(cuid())
  companyId    String                              @map("company_id")
  challengeId  String                              @map("challenge_id")
  influencerId String                              @map("influencer_id")
  description  String
  linkUrl      String?                             @map("link_url")
  fileUrl      String?                             @map("file_url")
  status       InfluencerChallengeSubmissionStatus @default(pending)
  reviewNote   String?                             @map("review_note")
  reviewedAt   DateTime?                           @map("reviewed_at")
  createdAt    DateTime                            @default(now()) @map("created_at")
  updatedAt    DateTime                            @updatedAt @map("updated_at")

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  challenge  InfluencerChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  influencer Influencer          @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  scores     InfluencerChallengeScore[]

  @@index([companyId, challengeId])
  @@index([companyId, influencerId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("influencer_challenge_submissions")
}

model InfluencerChallengeScore {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  challengeId  String   @map("challenge_id")
  influencerId String   @map("influencer_id")
  submissionId String?  @map("submission_id")
  points       Int
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company    Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  challenge  InfluencerChallenge            @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  influencer Influencer                     @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  submission InfluencerChallengeSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([companyId, challengeId])
  @@index([companyId, influencerId])
  @@index([companyId, submissionId])
  @@map("influencer_challenge_scores")
}

model WalletAccount {
  id               String   @id @default(cuid())
  companyId        String   @map("company_id")
  influencerId     String   @unique @map("influencer_id")
  availableBalance Decimal  @default(0) @map("available_balance") @db.Decimal(12, 2)
  pendingBalance   Decimal  @default(0) @map("pending_balance") @db.Decimal(12, 2)
  totalReceived    Decimal  @default(0) @map("total_received") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@unique([companyId, influencerId])
  @@index([companyId])
  @@index([influencerId])
  @@map("wallet_accounts")
}

model CompanyFinancialSettings {
  id                    String             @id @default(cuid())
  companyId             String             @unique @map("company_id")
  releaseMode           BalanceReleaseMode @default(immediate) @map("release_mode")
  monthlyReleaseDay     Int?               @map("monthly_release_day")
  defaultCommissionRate Decimal?           @default(10.00) @map("default_commission_rate") @db.Decimal(5, 2)
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_financial_settings")
}

model InfluencerCoupon {
  id           String                 @id @default(cuid())
  companyId    String                 @map("company_id")
  influencerId String                 @map("influencer_id")
  code         String
  status       InfluencerCouponStatus @default(active)
  startsAt     DateTime?              @map("starts_at")
  endsAt       DateTime?              @map("ends_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  commissionEvents CommissionEvent[]

  @@unique([companyId, code])
  @@index([companyId, influencerId])
  @@index([companyId, status])
  @@map("influencer_coupons")
}

model CommissionEvent {
  id                 String                @id @default(cuid())
  companyId          String                @map("company_id")
  influencerId       String                @map("influencer_id")
  couponId           String?               @map("coupon_id")
  sourceType         CommissionSourceType  @map("source_type")
  sourceId           String?               @map("source_id")
  status             CommissionEventStatus @default(pending)
  baseAmount         Decimal               @map("base_amount") @db.Decimal(12, 2)
  commissionRate     Decimal?              @map("commission_rate") @db.Decimal(5, 2)
  amount             Decimal               @db.Decimal(12, 2)
  competenceMonth    Int                   @map("competence_month")
  competenceYear     Int                   @map("competence_year")
  availableAt        DateTime?             @map("available_at")
  description        String?
  metadata           Json?
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  influencer Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  coupon     InfluencerCoupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]

  @@unique([companyId, sourceType, sourceId])
  @@index([companyId, influencerId, competenceYear, competenceMonth])
  @@index([companyId, status])
  @@index([companyId, couponId])
  @@map("commission_events")
}

model ImportedOrder {
  id            String              @id @default(cuid())
  companyId     String              @map("company_id")
  externalId    String              @map("external_id")
  customerEmail String?             @map("customer_email")
  couponCode    String?             @map("coupon_code")
  grossAmount   Decimal             @map("gross_amount") @db.Decimal(12, 2)
  status        ImportedOrderStatus
  source        OrderImportSource   @default(spreadsheet)
  orderedAt     DateTime            @map("ordered_at")
  rawPayload    Json?               @map("raw_payload")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, source, externalId])
  @@index([companyId, couponCode])
  @@index([companyId, orderedAt])
  @@index([companyId, status])
  @@map("imported_orders")
}

model WalletTransaction {
  id              String                     @id @default(cuid())
  companyId       String                     @map("company_id")
  influencerId    String                     @map("influencer_id")
  walletAccountId String                     @map("wallet_account_id")
  commissionEventId String?                  @map("commission_event_id")
  type            WalletTransactionType
  direction       WalletTransactionDirection
  status          WalletTransactionStatus
  amount          Decimal                    @db.Decimal(12, 2)
  description     String?
  metadata        Json?
  occurredAt      DateTime                   @default(now()) @map("occurred_at")
  createdAt       DateTime                   @default(now()) @map("created_at")

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  walletAccount WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  commissionEvent CommissionEvent? @relation(fields: [commissionEventId], references: [id], onDelete: SetNull)

  @@index([companyId, influencerId, createdAt])
  @@index([walletAccountId, createdAt])
  @@index([commissionEventId])
  @@index([companyId, type])
  @@map("wallet_transactions")
}

model CompanyMember {
  id        String       @id @default(cuid())
  companyId String       @map("company_id")
  userId    String       @map("user_id")
  role      MemberRole   @default(operator)
  status    MemberStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionOverrides CompanyMemberPermission[]

  @@unique([companyId, userId])
  @@index([companyId, role])
  @@index([userId])
  @@map("company_members")
}

model CompanyMemberPermission {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  memberId  String   @map("member_id")
  permission String
  allowed   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  member CompanyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, permission])
  @@index([companyId, permission])
  @@index([memberId])
  @@map("company_member_permissions")
}

model AuditLog {
  id        String      @id @default(cuid())
  companyId String?     @map("company_id")
  userId    String?     @map("user_id")
  action    AuditAction
  entity    String
  entityId  String?     @map("entity_id")
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
